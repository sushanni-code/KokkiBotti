<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.KokkiBotti" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color (yläpalkki, drawer-otsake) -->
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryVariant">@color/primary_green</item> <!-- Varmuuden vuoksi sama, tummempaa ei määritelty -->
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color (napit, korostukset) -->
        <item name="colorSecondary">@color/accent_green</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimary</item>
        
        <!-- Window background -->
        <item name="android:windowBackground">@color/light_background</item>
    </style>

    <style name="Theme.KokkiBotti" parent="Base.Theme.KokkiBotti" />

    <style name="Widget.App.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.BottomNavigationView</item>
    </style>

    <style name="ThemeOverlay.App.BottomNavigationView" parent="">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorOnPrimary">@color/accent_green</item>
    </style>
</resources>