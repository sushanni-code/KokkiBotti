<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.KokkiBotti" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color (yläpalkki, drawer-otsake) -->
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/soft_pink</item>

        <!-- Secondary brand color (napit, korostukset) -->
        <item name="colorSecondary">@color/primary_light</item>
        <item name="colorOnSecondary">@color/primary_dark</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimary</item>
        
        <!-- Window background -->
        <item name="android:windowBackground">@color/black_pure</item>
        <item name="android:textColorPrimary">@color/neutral_gray</item>
    </style>

    <style name="Theme.KokkiBotti" parent="Base.Theme.KokkiBotti" />

    <style name="Widget.App.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.BottomNavigationView</item>
        <item name="backgroundTint">@color/primary_dark</item>
        <item name="itemIconTint">@color/bottom_nav_colors</item>
        <item name="itemTextColor">@color/bottom_nav_text_colors</item>
        <item name="itemRippleColor">@color/soft_pink</item>
    </style>

    <style name="ThemeOverlay.App.BottomNavigationView" parent="">
        <!-- Alapalkin aktiivinen fragmentti (pilleri) -->
        <item name="colorSecondaryContainer">@color/soft_pink</item>
        <item name="colorOnSecondaryContainer">@color/primary_dark</item>
        <item name="colorOnSurfaceVariant">@color/neutral_gray</item>
    </style>

    <!-- Nappien tyyli -->
    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary_light</item>
        <item name="android:textColor">@color/primary_dark</item>
    </style>

    <!-- Dialogit -->
    <style name="Theme.App.Dialog.Alert" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/accent_pink</item>
        <item name="colorOnSurface">@color/primary_dark</item>
        <item name="colorPrimary">@color/primary_dark</item>
    </style>

    <style name="Theme.App.Dialog.Selection" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/primary_light</item>
        <item name="colorOnSurface">@color/primary_dark</item>
        <item name="colorPrimary">@color/primary_dark</item>
    </style>
</resources>