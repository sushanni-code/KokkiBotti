<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.KokkiBotti" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color (yläpalkki, drawer-otsake) -->
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/neutral_gray</item>

        <!-- Secondary brand color (napit, korostukset) -->
        <item name="colorSecondary">@color/primary_light</item>
        <item name="colorOnSecondary">@color/soft_pink</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimary</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/black_pure</item>
        <item name="android:textColorPrimary">@color/neutral_gray</item>
    </style>
</resources>